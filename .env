# ============================================================
# ASTRO STORAGE — VARIÁVEIS DE AMBIENTE
# ============================================================

# ---------- PORTA DO SERVIDOR ----------
PORT=3000

# ---------- MODO DE EXECUÇÃO ----------
# "production" = cookies secure, HSTS, sem log da URL admin
NODE_ENV=production

# ---------- AUTENTICAÇÃO (OBRIGATÓRIOS) ----------
ADMIN_USER=nanagui
ADMIN_PASS=001010GGZEHEN

# ---------- SEGURANÇA JWT ----------
JWT_SECRET=super_secret_jwt_key_2024_change_me

# ---------- SEGURANÇA DOS COOKIES ----------
COOKIE_SECRET=super_secret_cookie_key_2024_change_me

# ---------- WEBHOOK DO DISCORD (OPCIONAL) ----------
DISCORD_WEBHOOK_URL=

# ---------- MODO MANUTENÇÃO ----------
# "true" = todos os scripts retornam "Em manutenção"
MAINTENANCE_MODE=false

# ---------- BANCO DE DADOS POSTGRESQL ----------
# Use a string de conexão do seu provedor (Render, Supabase, Railway, etc.)
# Exemplo para Supabase:
# DATABASE_URL=postgresql://postgres:senha@db.xxxxx.supabase.co:5432/postgres
# Exemplo para Render PostgreSQL:
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/astro